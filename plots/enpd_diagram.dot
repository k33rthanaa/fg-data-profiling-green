digraph EnPD {
  rankdir=LR;
  graph [fontname="Helvetica", fontsize=11, labelloc=t,
         label="Energy Processing Diagram - baseline fg-data-profiling (20 MB measured, 15 W TDP, 365 runs/yr)"];
  node  [fontname="Helvetica", fontsize=10, shape=box, style="filled", fillcolor="#f4f4f4", color="#555555"];
  edge  [color="#333333", arrowsize=0.8];

  /* ---- Energy label banner ---- */
  subgraph cluster_label {
    label="Energy Label"; fontcolor="#2E7D32"; color="#2E7D32"; style="rounded"; bgcolor="#f2fbf2";
    L1 [label="Total per run\n0.0378 Wh\n(9.07 s x 15 W TDP)", fillcolor="#eafaea"];
    L2 [label="Per year (365 runs)\n13.8 Wh/year", fillcolor="#eafaea"];
    L3 [label="Carbon per year\n4.07 g CO2eq\n(0.295 kg/kWh)", fillcolor="#eafaea"];
    L4 [label="Peak RSS per run\n535 MB (measured)", fillcolor="#eafaea"];
    L5 [label="Useful work\n1 EDA report / run", fillcolor="#eafaea"];
    L1 -> L2 -> L3 -> L4 -> L5 [style=invis];
  }

  /* ---- storage / IO ---- */
  CSV  [label="CSV Log File (Disk)\n0.015 GB | +0 GB/yr", fillcolor="#eef2f7"];
  HTML [label="HTML Report (Disk)\n0.005 GB | +1.825 GB/yr", fillcolor="#eef2f7"];
  USER [label="Data Scientist /\nCI-CD Pipeline", shape=box, fillcolor="#ffffff"];

  /* ---- pipeline stages ---- */
  S1 [label="Stage 1 - Data Load & Type Inference\n0.0094 Wh/run\npd.read_csv, no dtype hints,\nall 10 cols as object, type inference",
      fillcolor="#fdecec", color="#BE1B28", penwidth=2];
  DF [label="DataFrame (RAM)\n0.021 GB  [MEMORY HOTSPOT]\nobject-dtype inflation",
      fillcolor="#fdecec", color="#BE1B28", penwidth=2];

  S2 [label="Stage 2 - Descriptive Stats\n0.0114 Wh/run\nmean, std, quantiles, skew,\nkurtosis, null counts (per cell)"];
  S3 [label="Stage 3 - Correlation Engine\n0.0114 Wh/run  [COMPUTE / RSS HOTSPOT]\nPearson, Spearman, Cramer V, Kendall,\nPhi-K over N x N pairs; allocates Temp Numeric Copy (~0.028 GB RAM)",
      fillcolor="#fdecec", color="#BE1B28", penwidth=2];
  S4 [label="Stage 4 - Distribution Analysis\n0.0038 Wh/run\nhistogram bins, value counts,\ntext patterns"];

  CACHE [label="Statistics Cache (RAM)\n0.002 GB | +0 GB/yr", fillcolor="#eef2f7"];
  S5 [label="Stage 5 - HTML Rendering\n0.0019 Wh/run\nJinja2 template, inline SVG,\nbase64 PNG, minify"];

  /* ---- flow ---- */
  CSV -> S1 -> DF;
  DF -> S2; DF -> S3; DF -> S4;
  S2 -> CACHE; S3 -> CACHE; S4 -> CACHE;
  CACHE -> S5 -> HTML -> USER;

  { rank=same; S2; S3; S4; }
}
